{
  "productName": "aetherio",
  "version": "0.3.0",
  "identifier": "com.aetherio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aetherio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#1f1f1fff",
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* https: wss: ws://localhost:*; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; media-src 'self' http://127.0.0.1:* https:; frame-src https:; worker-src 'self' blob:; child-src 'self' blob: https:"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "aetherio"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzQzkxOTM4QjkwODk2MwpSV1JqaVpDTGs1RThBUmpCNVpWTG9OL3V1TjJwUlVWZG8vWnBEZzVZZEVHUTVnNlc5amNLRWVjSQo=",
      "endpoints": [
        "https://github.com/trklll/aetherio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "licenseFile": "nsis/LICENSE.txt",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "installerHooks": "nsis/installer-hooks.nsh",
        "startMenuFolder": "Aetherio"
      }
    },
    "resources": [
      "bin/mpv"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
