  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-updater",
  "description": "Allows the desktop app to install signed updates and restart itself.",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "updater:default",
    "process:allow-restart"
  ]
}
